# ========================================
# Variables de Entorno - Frontend
# ========================================

# Puerto en el que escuchará nginx (Dokploy lo mapea automáticamente)
PORT=80

# URL del backend (servicio interno de Dokploy)
# Ejemplo si el servicio backend se llama "backend" en Dokploy:
BACKEND_URL=http://backend:3000

# Si tienes dominios públicos configurados, también puedes usar:
# BACKEND_URL=https://api.tudominio.com
